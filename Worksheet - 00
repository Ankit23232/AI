{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNtjES5rGkbCb8M10R77LGj"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["Task - 1"],"metadata":{"id":"EgKi58b6gF7h"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"lmFt2s7XbXeT","colab":{"base_uri":"https://localhost:8080/"},"outputId":"cfcbc886-87a3-4292-b38c-8f4f2a0dea0b"},"outputs":[{"name":"stdout","output_type":"stream","text":["Conversion type (length, weight, volume): length\n"]}],"source":["def convert_units(conversion_type, value, unit_from):\n","\n","    if conversion_type == \"length\":\n","        if unit_from == \"m\":\n","            return value * 3.28084, \"ft\"\n","        elif unit_from == \"ft\":\n","            return value / 3.28084, \"m\"\n","    elif conversion_type == \"weight\":\n","        if unit_from == \"kg\":\n","            return value * 2.20462, \"lbs\"\n","        elif unit_from == \"lbs\":\n","            return value / 2.20462, \"kg\"\n","    elif conversion_type == \"volume\":\n","        if unit_from == \"L\":\n","            return value * 0.264172, \"gal\"\n","        elif unit_from == \"gal\":\n","            return value / 0.264172, \"L\"\n","    return None, None\n","\n","\n","conversion_type = input(\"Conversion type (length, weight, volume): \")\n","try:\n","    value = float(input(\"Enter the value to convert: \"))\n","except ValueError:\n","    print(\"Please enter a valid number!\")\n","    exit()\n","\n","unit_from = input(\"Enter the current unit: \")\n","\n","converted_value, new_unit = convert_units(conversion_type, value, unit_from)\n","\n","if converted_value is None:\n","    print(\"Invalid conversion type or unit!\")\n","else:\n","    print(f\"{value} {unit_from} = {converted_value:.2f} {new_unit}\")"]},{"cell_type":"markdown","source":["Task - 2\n"],"metadata":{"id":"DIJI6vF7hFTB"}},{"cell_type":"code","source":["def calculate_sum(numbers):\n","    return sum(numbers)\n","\n","def calculate_average(numbers):\n","    return sum(numbers) / len(numbers)\n","\n","def calculate_max(numbers):\n","    return max(numbers)\n","\n","def calculate_min(numbers):\n","    return min(numbers)\n","\n","\n","operation = input(\"Choose operation (sum, average, max, min): \").strip().lower()\n","\n","numbers_input = input(\"Enter numbers separated by spaces: \").strip()\n","\n","try:\n","    numbers = [float(num) for num in numbers_input.split()]\n","\n","    if not numbers:\n","        raise ValueError(\"List of numbers is empty!\")\n","\n","    if operation == \"sum\":\n","        result = calculate_sum(numbers)\n","    elif operation == \"average\":\n","        result = calculate_average(numbers)\n","    elif operation == \"max\":\n","        result = calculate_max(numbers)\n","    elif operation == \"min\":\n","        result = calculate_min(numbers)\n","    else:\n","        raise ValueError(\"Invalid operation selected!\")\n","\n","    print(f\"The result of {operation} operation is: {result}\")\n","\n","except ValueError as ve:\n","    print(\"Error:\", ve)\n","except Exception as e:\n","    print(\"An unexpected error occurred:\", e)"],"metadata":{"id":"b8c5q2XNg1LY"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["Exercise on List Manuplation"],"metadata":{"id":"s1-UV3WHhkam"}},{"cell_type":"code","source":["def extract_every_other(lst):\n","\n","    #Extract every other element from a list, starting from the first element.\n","\n","    return lst[::2]\n","\n","print(\"Every other element:\", extract_every_other([1, 2, 3, 4, 5, 6]))\n","\n","\n","def get_sublist(lst, start, end):\n","\n","    #Return a sublist from start to end (inclusive).\n","\n","    return lst[start:end+1]\n","\n","print(\"Sublist from index 2 to 4:\", get_sublist([1, 2, 3, 4, 5, 6], 2, 4))\n","\n","\n","def reverse_list(lst):\n","\n","    #Return a reversed list using slicing.\n","\n","    return lst[::-1]\n","\n","print(\"Reversed list:\", reverse_list([1, 2, 3, 4, 5]))\n","\n","\n","def remove_first_last(lst):\n","\n","    #Remove the first and last elements of a list.\n","\n","    return lst[1:-1]\n","\n","print(\"Without first and last:\", remove_first_last([1, 2, 3, 4, 5]))\n","\n","\n","def get_first_n(lst, n):\n","\n","    #Return the first n elements of a list.\n","\n","    return lst[:n]\n","\n","print(\"First 3 elements:\", get_first_n([1, 2, 3, 4, 5], 3))  # [1, 2, 3]\n","\n","\n","def get_last_n(lst, n):\n","\n","    #Return the last n elements of a list.\n","\n","    return lst[-n:]\n","\n","print(\"Last 2 elements:\", get_last_n([1, 2, 3, 4, 5], 2))\n","\n","def reverse_skip(lst):\n","\n","    #Extract elements in reverse order starting from the second-to-last,\n","    #skipping one element in between.\n","\n","    return lst[-2::-2]\n","\n","print(\"Reverse skip:\", reverse_skip([1, 2, 3, 4, 5, 6]))"],"metadata":{"id":"HDtkJRtvh49P"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["Exercise on Nested List"],"metadata":{"id":"SQndVKFbivtJ"}},{"cell_type":"code","source":["def flatten(lst):\n","    \"\"\"\n","    Flatten a nested list (one level) into a single list.\n","    \"\"\"\n","    flat_list = []\n","    for item in lst:\n","        flat_list.extend(item)\n","    return flat_list\n","\n","print(\"Flatten:\", flatten([[1, 2], [3, 4], [5]]))\n","\n","\n","def access_nested_element(lst, indices):\n","    \"\"\"\n","    Access a specific element in a nested list given its indices.\n","    \"\"\"\n","    element = lst\n","    for idx in indices:\n","        element = element[idx]\n","    return element\n","\n","nested_lst = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]\n","print(\"Access element:\", access_nested_element(nested_lst, [1, 2]))\n","\n","\n","def sum_nested(lst):\n","    \"\"\"\n","    Sum all numbers in a nested list (any depth).\n","    \"\"\"\n","    total = 0\n","    for item in lst:\n","        if isinstance(item, list):\n","            total += sum_nested(item)\n","        else:\n","            total += item\n","    return total\n","\n","print(\"Sum nested:\", sum_nested([[1, 2], [3, [4, 5]], 6]))\n","\n","\n","def remove_element(lst, elem):\n","    \"\"\"\n","    Remove all occurrences of elem from a nested list (one level).\n","    \"\"\"\n","    new_list = []\n","    for sublist in lst:\n","        new_sublist = [x for x in sublist if x != elem]\n","        new_list.append(new_sublist)\n","    return new_list\n","\n","print(\"Remove element:\", remove_element([[1, 2], [3, 2], [4, 5]], 2))\n","\n","\n","def find_max(lst):\n","    \"\"\"\n","    Find the maximum element in a nested list (any depth).\n","    \"\"\"\n","    max_val = float('-inf')\n","    for item in lst:\n","        if isinstance(item, list):\n","            max_val = max(max_val, find_max(item))\n","        else:\n","            max_val = max(max_val, item)\n","    return max_val\n","\n","print(\"Max element:\", find_max([[1, 2], [3, [4, 5]], 6]))\n","\n","\n","def count_occurrences(lst, elem):\n","    \"\"\"\n","    Count how many times elem appears in a nested list (any depth).\n","    \"\"\"\n","    count = 0\n","    for item in lst:\n","        if isinstance(item, list):\n","            count += count_occurrences(item, elem)\n","        else:\n","            if item == elem:\n","                count += 1\n","    return count\n","\n","print(\"Count occurrences:\", count_occurrences([[1, 2], [2, 3], [2, 4]], 2))\n","\n","\n","def deep_flatten(lst):\n","    \"\"\"\n","    Flatten a nested list of any depth into a single list.\n","    \"\"\"\n","    flat_list = []\n","    for item in lst:\n","        if isinstance(item, list):\n","            flat_list.extend(deep_flatten(item))\n","        else:\n","            flat_list.append(item)\n","    return flat_list\n","\n","print(\"Deep flatten:\", deep_flatten([[[1, 2], [3, 4]], [[5, 6], [7, 8]]]))\n","\n","\n","def average_nested(lst):\n","    \"\"\"\n","    Calculate the average of all elements in a nested list (any depth).\n","    \"\"\"\n","    flat_list = deep_flatten(lst)\n","    if len(flat_list) == 0:\n","        return 0\n","    return sum(flat_list) / len(flat_list)\n","\n","print(\"Nested average:\", average_nested([[1, 2], [3, 4], [5, 6]]))"],"metadata":{"id":"H6ISoGaui06n"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["Basic Vector and Matrix Operation with NumPy"],"metadata":{"id":"NnRk6A6NlheJ"}},{"cell_type":"markdown","source":["Problem - 1 Array creation"],"metadata":{"id":"FpwJyzUCoyJr"}},{"cell_type":"code","source":["import numpy as np\n","empty_array = np.empty((2, 2))\n","print(\"Empty array 2x2: \", empty_array)"],"metadata":{"id":"BR4TW7jslrXr"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","one_array = np.ones((4, 2))\n","print(\"All one array 4x2:\", one_array)"],"metadata":{"id":"iYx8Bu9GmMvl"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","fill_value = 5\n","filled_array = np.full((3, 3), fill_value, dtype=int)\n","print(\"Array filled with 5:\", filled_array)"],"metadata":{"id":"MRD7F2gommA8"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","orgi_array = np.array([[1, 2, 3], [7, 8, 9]])\n","zeros_like_array = np.zeros_like(orgi_array)\n","print(\"Zero like original array:\", zeros_like_array)"],"metadata":{"id":"zLAmdEZrnJD7"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import numpy as np\n","ones_like_array = np.ones_like(orgi_array)\n","print(\"Ones like array:\", ones_like_array)"],"metadata":{"id":"2T5j-Jo9n31i"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["new_list = [1, 2, 3, 4, 5, 6]\n","array_from_list = np.array(new_list)\n","print(\"NumPy array from list:\", array_from_list)"],"metadata":{"id":"Ihw1tvB3obgf"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source"